{
  "id": "aitoearn",
  "name": "AiToEarn",
  "description": "Bridge to AiToEarn MCP server for social media management tools",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "API Key for authentication"
      },
      "baseUrl": {
        "type": "string",
        "description": "Server base URL",
        "default": "https://aitoearn.ai/api"
      }
    },
    "required": []
  },
  "uiHints": {
    "apiKey": {
      "label": "API Key",
      "placeholder": "Enter your AiToEarn API key",
      "sensitive": true
    },
    "baseUrl": {
      "label": "Base URL",
      "placeholder": "https://aitoearn.ai/api",
      "advanced": true
    }
  }
}
