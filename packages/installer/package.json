{
  "name": "@aitoearn/openclaw-plugin-cli",
  "version": "1.0.16",
  "type": "module",
  "main": "./dist/installer/src/index.js",
  "types": "./dist/installer/src/index.d.ts",
  "bin": {
    "openclaw-plugin-cli": "dist/installer/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yikart/aitoearn-openclaw-plugin.git"
  },
  "scripts": {
    "prebuild": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node --input-type=module -e \"import { chmodSync } from 'node:fs'; chmodSync('dist/installer/src/index.js', 0o755);\"",
    "prepack": "npm run build",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^14.0.3",
    "json5": "^2.2.3",
    "zod": "^3.24.0"
  }
}
