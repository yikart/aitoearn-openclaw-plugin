  {
    "name": "publishRestrictions",
    "description": "Get platform-specific publishing restrictions and validation rules for one or more platforms. You must specify at least one platform to get its restrictions. Provide multiple platforms to get restrictions for all of them in one call. Platform values must be one of: douyin, xhs, wxSph, KWAI, youtube, wxGzh, bilibili, twitter, tiktok, facebook, instagram, threads, pinterest, linkedin, google_business.",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "properties": {
        "platforms": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "douyin",
              "xhs",
              "wxSph",
              "KWAI",
              "youtube",
              "wxGzh",
              "bilibili",
              "twitter",
              "tiktok",
              "facebook",
              "instagram",
              "threads",
              "pinterest",
              "linkedin",
              "google_business"
            ]
          },
          "description": "Array of platforms to get restrictions for. Must specify at least one platform."
        }
      },
      "required": [
        "platforms"
      ]
    }
  },
  {
    "name": "publishPostToBilibili",
    "description": "Publish video content to Bilibili. ONLY video content is supported (image-only or text-only posts are not supported). Option parameters: \n- tid: category id (required) - get from tool getBilibiliContentCategories and recommend based on content\n- no_reprint: 0 (allow reprint) or 1 (disable reprint), default: 0\n- copyright: 1 (original) or 2 (forward), default: 1\n- source: source link (required when copyright is 2)\n\nWorkflow: \n(1) Confirm: title, description, REQUIRED video URL, optional cover URL, topics (at least one), publishing time\n(2) Call getBilibiliContentCategories if category not specified\n(3) Call publishPostToBilibili with all parameters\n(4) Return flowId and status for tracking",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "properties": {
        "accountId": {
          "type": "string",
          "description": "account id"
        },
        "userTaskId": {
          "description": "user task id",
          "type": "string"
        },
        "publishTime": {
          "description": "publish time",
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "title": {
          "type": "string",
          "description": "title"
        },
        "desc": {
          "description": "description",
          "type": "string"
        },
        "videoUrl": {
          "type": "string",
          "description": "video url"
        },
        "coverUrl": {
          "type": "string",
          "description": "cover url"
        },
        "topics": {
          "minItems": 1,
          "maxItems": 10,
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "topics (hashtags); 1-10 required"
        },
        "option": {
          "type": "object",
          "properties": {
            "tid": {
              "default": 160,
              "description": "category id",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "no_reprint": {
              "default": 0,
              "description": "disable reprint",
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            "copyright": {
              "default": 1,
              "description": "original or forward",
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            "source": {
              "description": "source link",
              "type": "string"
            }
          }
        }
      },
      "required": [
        "accountId",
        "title",
        "videoUrl",
        "coverUrl",
        "topics"
      ]
    }
  },
